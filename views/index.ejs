<!DOCTYPE html>
<html>

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="initial-scale=1,maximum-scale=1,user-scalable=no" />
    <title>MapTiler Geocoding Leaflet</title>

    <link rel="stylesheet" href="/styles.css"/>

    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

    <script src="https://cdn.maptiler.com/maptiler-geocoding-control/v1.3.2/leaflet.umd.js"></script>
    <link href="https://cdn.maptiler.com/maptiler-geocoding-control/v1.3.2/style.css" rel="stylesheet">
</head>

<body>

    <h1>Precisa de protetor solar?</h1>

    <div id="map">
        <pre id="info">Mova o mouse no mapa...</pre>
    </div>

    <div class="important">
        <form action="/protetor" method="post">
            <input type="hidden" name="lat" value="" id="latform">
            <input type="hidden" name="lng" value="" id="lngform">
            <button type="submit" class="bloqueado" id="submitForm">Selecione um local</button>
        </form>
    </div>

<script src="/main.js" defer></script>
</body>

</html>